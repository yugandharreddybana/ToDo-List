# =====================================================================
# Todo Productivity Suite — environment configuration
# Copy this file to `.env` at the repository root and fill in real values.
# =====================================================================

# ---------- Frontend (packages/frontend) ----------
VITE_API_BASE_URL=http://localhost:3001/api
VITE_APP_NAME="Productivity Suite"

# Optional: direct Gemini key for legacy client-side calls during migration.
# In production, AI calls should go through the middleware.
GEMINI_API_KEY=

# ---------- Middleware (packages/middleware) ----------
MIDDLEWARE_PORT=3001
MIDDLEWARE_CORS_ORIGIN=http://localhost:3000
BACKEND_URL=http://localhost:8080

# JWT — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-me-access-secret
JWT_REFRESH_SECRET=replace-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Claude API (server-side only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# Redis (session + AI response cache)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---------- Backend (services/backend) ----------
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=productivity
POSTGRES_USER=productivity
POSTGRES_PASSWORD=changeme

# JWT (must match middleware secrets so tokens verify end-to-end)
APP_JWT_SECRET=replace-me-access-secret

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------- Docker Compose ----------
COMPOSE_PROJECT_NAME=productivity-suite
